00000000                             1  *-----------------------------------------------------------------
00000000                             2  * EASy68K Hardware demo  —  Knight Rider + 32-bit hex counter
00000000                             3  *
00000000                             4  * Open  Window > Hardware.  In the (red) "Auto Interval" box pick an
00000000                             5  * IRQ, set the mSec rate and press Start.  The timer interrupt then:
00000000                             6  *   - sweeps a smooth "Knight Rider" light across the 8 LEDs (FF8010)
00000000                             7  *   - advances a 32-bit HEX COUNTER shown on the eight 7-seg digits
00000000                             8  * Flip SWITCH 7 (leftmost) ON for FAST, OFF for SLOW.
00000000                             9  * Hold PUSH BUTTON 0 (rightmost) to reset the counter.
00000000                            10  *-----------------------------------------------------------------
00000000  =00FF8000                 11  SEG7    EQU     $00FF8000      digit n at SEG7 + 2*n  (digit 0 = MS nibble)
00000000  =00FF8010                 12  LEDS    EQU     $00FF8010      8 LEDs
00000000  =00FF8020                 13  SWTCH   EQU     $00FF8020      8 switches
00000000  =00FF8030                 14  BTNS    EQU     $00FF8030      8 push buttons (active low)
00000000                            15  
